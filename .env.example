NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
ADAPTIFAI_BACKEND_URL=http://127.0.0.1:8000
ADAPTIFAI_DEMO_CREDITS=240

# Keep real secrets in .env.local only. Never commit them.
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4o
GOOGLE_FONTS_API_KEY=

ADAPTIFAI_TROCR_MODEL=microsoft/trocr-base-printed
ADAPTIFAI_INPAINT_BACKEND=stable-diffusion
ADAPTIFAI_INPAINT_MODEL=runwayml/stable-diffusion-inpainting
ADAPTIFAI_INPAINT_MAX_SIDE=128
ADAPTIFAI_INPAINT_STEPS=4

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_DESTINATION_ID=
STRIPE_WEBHOOK_NAME=
STRIPE_WEBHOOK_ENDPOINT_URL=
STRIPE_CUSTOMER_ID=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_SCALE=
STRIPE_PAYMENT_LINK_STARTER=
STRIPE_PAYMENT_LINK_STUDIO=
STRIPE_PAYMENT_LINK_SCALE=
